var f;
var g;

{
  var localVar = "localVar";
  fun f_() {
    print localVar;
    localVar = "after f";
    print localVar;
  }
  f = f_;

  fun g_() {
    print localVar;
    localVar = "after g";
    print localVar;
  }
  g = g_;
}

f();
// expect: localVar
// expect: after f

g();
// expect: after f
// expect: after g
